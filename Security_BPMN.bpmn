<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://securechat.security.bpmn">

  <collaboration id="Collab_Security">
    <participant id="Pool_Client" name="Client (User)" processRef="Proc_Client" />
    <participant id="Pool_Server" name="Server &amp; Database" processRef="Proc_Server" />

    <messageFlow id="MF_PubKey"       name="PUBKEY"              sourceRef="Task_S_SendPubKey"      targetRef="Task_C_ReceivePubKey" />
    <messageFlow id="MF_KeyExchange"  name="KEY_EXCHANGE"         sourceRef="Task_C_SendKeyExchange" targetRef="Task_S_ReceiveKeyExchange" />
    <messageFlow id="MF_LoginSuccess" name="LOGIN_SUCCESS"        sourceRef="Task_S_SendLoginOK"     targetRef="Task_C_ReceiveLoginOK" />
    <messageFlow id="MF_LoginFail"    name="LOGIN_FAIL"           sourceRef="Task_S_SendLoginFail"   targetRef="Task_C_ReceiveLoginFail" />
    <messageFlow id="MF_ChatMsg"      name="CHAT|token"           sourceRef="Task_C_SendChat"        targetRef="Task_S_ReceiveChat" />
    <messageFlow id="MF_MsgDelivery"  name="MSG|from|AES(pesan)"  sourceRef="Task_S_ForwardMsg"      targetRef="Task_C_ReceiveMsg" />
    <messageFlow id="MF_History"      name="HISTORY"              sourceRef="Task_S_SendHistory"     targetRef="Task_C_ReceiveHistory" />
    <messageFlow id="MF_TokenRefresh" name="TOKEN_REFRESHED"      sourceRef="Task_S_SendNewToken"    targetRef="Task_C_ReceiveNewToken" />
  </collaboration>

  <!-- ═══ PROCESS CLIENT ═══ -->
  <process id="Proc_Client" isExecutable="false">
    <laneSet id="LaneSet_Client">
      <lane id="Lane_C_Password" name="1. Password (SHA-256)">
        <flowNodeRef>Start_C</flowNodeRef>
        <flowNodeRef>Task_C_InputCredential</flowNodeRef>
        <flowNodeRef>Task_C_HashPassword</flowNodeRef>
        <flowNodeRef>GW_C_RegOrLogin</flowNodeRef>
        <flowNodeRef>Task_C_SendRegister</flowNodeRef>
        <flowNodeRef>Task_C_SendLogin</flowNodeRef>
      </lane>
      <lane id="Lane_C_KeyExchange" name="2. Key Exchange (RSA-2048)">
        <flowNodeRef>Task_C_ReceivePubKey</flowNodeRef>
        <flowNodeRef>Task_C_GenerateAES</flowNodeRef>
        <flowNodeRef>Task_C_EncryptAES</flowNodeRef>
        <flowNodeRef>Task_C_SendKeyExchange</flowNodeRef>
      </lane>
      <lane id="Lane_C_Session" name="3. Session Token">
        <flowNodeRef>Task_C_ReceiveLoginOK</flowNodeRef>
        <flowNodeRef>Task_C_ReceiveLoginFail</flowNodeRef>
        <flowNodeRef>Task_C_StoreToken</flowNodeRef>
        <flowNodeRef>Task_C_ReceiveHistory</flowNodeRef>
        <flowNodeRef>Task_C_TokenCountdown</flowNodeRef>
        <flowNodeRef>GW_C_TokenExpiring</flowNodeRef>
        <flowNodeRef>Task_C_RequestRefresh</flowNodeRef>
        <flowNodeRef>Task_C_ReceiveNewToken</flowNodeRef>
        <flowNodeRef>End_C_LoginFail</flowNodeRef>
      </lane>
      <lane id="Lane_C_Chat" name="4. Enkripsi Pesan (AES-256 + per-message IV)">
        <flowNodeRef>Task_C_EncryptMsg</flowNodeRef>
        <flowNodeRef>Task_C_SendChat</flowNodeRef>
        <flowNodeRef>Task_C_ReceiveMsg</flowNodeRef>
        <flowNodeRef>Task_C_DecryptMsg</flowNodeRef>
        <flowNodeRef>Task_C_DisplayMsg</flowNodeRef>
        <flowNodeRef>End_C</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="Start_C" name="Buka Aplikasi" />
    <sequenceFlow id="SF_C1" sourceRef="Start_C" targetRef="Task_C_ReceivePubKey" />

    <task id="Task_C_ReceivePubKey" name="Terima RSA&#10;Public Key dari Server" />
    <sequenceFlow id="SF_C2" sourceRef="Task_C_ReceivePubKey" targetRef="Task_C_GenerateAES" />
    <task id="Task_C_GenerateAES" name="Generate AES Key&#10;256-bit + IV 128-bit&#10;(RANDOM)" />
    <sequenceFlow id="SF_C3" sourceRef="Task_C_GenerateAES" targetRef="Task_C_EncryptAES" />
    <task id="Task_C_EncryptAES" name="Enkripsi AES Key+IV&#10;pakai RSA Public Key&#10;(OAEP Padding)" />
    <sequenceFlow id="SF_C4" sourceRef="Task_C_EncryptAES" targetRef="Task_C_SendKeyExchange" />
    <task id="Task_C_SendKeyExchange" name="Kirim KEY_EXCHANGE&#10;ke Server" />
    <sequenceFlow id="SF_C5" sourceRef="Task_C_SendKeyExchange" targetRef="Task_C_InputCredential" />

    <task id="Task_C_InputCredential" name="Input Username&#10;+ Password" />
    <sequenceFlow id="SF_C6" sourceRef="Task_C_InputCredential" targetRef="Task_C_HashPassword" />
    <task id="Task_C_HashPassword" name="Hash Password&#10;SHA-256 di Client&#10;(tidak dikirim plaintext)" />
    <sequenceFlow id="SF_C7" sourceRef="Task_C_HashPassword" targetRef="GW_C_RegOrLogin" />
    <exclusiveGateway id="GW_C_RegOrLogin" name="Register&#10;atau Login?" />
    <sequenceFlow id="SF_C8a" name="Register" sourceRef="GW_C_RegOrLogin" targetRef="Task_C_SendRegister" />
    <sequenceFlow id="SF_C8b" name="Login"    sourceRef="GW_C_RegOrLogin" targetRef="Task_C_SendLogin" />
    <task id="Task_C_SendRegister" name="Kirim REGISTER&#10;|username|sha256|" />
    <task id="Task_C_SendLogin"    name="Kirim LOGIN&#10;|username|sha256|" />
    <sequenceFlow id="SF_C9"  sourceRef="Task_C_SendRegister" targetRef="Task_C_ReceiveLoginOK" />
    <sequenceFlow id="SF_C10" sourceRef="Task_C_SendLogin"    targetRef="Task_C_ReceiveLoginOK" />

    <task id="Task_C_ReceiveLoginOK"   name="Terima LOGIN_SUCCESS&#10;|role|token|expiry|" />
    <task id="Task_C_ReceiveLoginFail" name="Terima LOGIN_FAIL&#10;Tampilkan Error" />
    <sequenceFlow id="SF_C11a" sourceRef="Task_C_ReceiveLoginOK"   targetRef="Task_C_StoreToken" />
    <sequenceFlow id="SF_C11b" sourceRef="Task_C_ReceiveLoginFail" targetRef="End_C_LoginFail" />
    <task id="Task_C_StoreToken"    name="Simpan Session Token&#10;di Memori Client" />
    <sequenceFlow id="SF_C12" sourceRef="Task_C_StoreToken" targetRef="Task_C_ReceiveHistory" />
    <task id="Task_C_ReceiveHistory" name="Terima HISTORY&#10;Dekripsi AES → Tampilkan" />
    <sequenceFlow id="SF_C13" sourceRef="Task_C_ReceiveHistory" targetRef="Task_C_TokenCountdown" />
    <task id="Task_C_TokenCountdown" name="Timer Countdown Token&#10;(Tick setiap 1 detik)" />
    <sequenceFlow id="SF_C14" sourceRef="Task_C_TokenCountdown" targetRef="GW_C_TokenExpiring" />
    <exclusiveGateway id="GW_C_TokenExpiring" name="Sisa token&#10;&lt; 2 menit?" />
    <sequenceFlow id="SF_C15a" name="Ya"    sourceRef="GW_C_TokenExpiring" targetRef="Task_C_RequestRefresh" />
    <sequenceFlow id="SF_C15b" name="Tidak" sourceRef="GW_C_TokenExpiring" targetRef="Task_C_EncryptMsg" />
    <task id="Task_C_RequestRefresh" name="Kirim TOKEN_REFRESH&#10;|username|old_token|" />
    <sequenceFlow id="SF_C16" sourceRef="Task_C_RequestRefresh" targetRef="Task_C_ReceiveNewToken" />
    <task id="Task_C_ReceiveNewToken" name="Terima TOKEN_REFRESHED&#10;Update Token + Expiry" />
    <sequenceFlow id="SF_C17" sourceRef="Task_C_ReceiveNewToken" targetRef="Task_C_EncryptMsg" />
    <endEvent id="End_C_LoginFail" name="Login Gagal" />

    <task id="Task_C_EncryptMsg" name="Generate IV Random baru&#10;AesEncryptMsg(pesan, aesKey)&#10;→ Base64(IV + ciphertext)" />
    <sequenceFlow id="SF_C18" sourceRef="Task_C_EncryptMsg" targetRef="Task_C_SendChat" />
    <task id="Task_C_SendChat" name="Kirim CHAT&#10;|from|to|cipher|token|" />
    <sequenceFlow id="SF_C19" sourceRef="Task_C_SendChat" targetRef="Task_C_ReceiveMsg" />
    <task id="Task_C_ReceiveMsg" name="Terima MSG&#10;|from|AES(pesan)|" />
    <sequenceFlow id="SF_C20" sourceRef="Task_C_ReceiveMsg" targetRef="Task_C_DecryptMsg" />
    <task id="Task_C_DecryptMsg" name="AesDecrypt(cipher,&#10;aesKey, aesIV)" />
    <sequenceFlow id="SF_C21" sourceRef="Task_C_DecryptMsg" targetRef="Task_C_DisplayMsg" />
    <task id="Task_C_DisplayMsg" name="Tampilkan Pesan&#10;di Chat Window" />
    <sequenceFlow id="SF_C22" sourceRef="Task_C_DisplayMsg" targetRef="End_C" />
    <endEvent id="End_C" name="Selesai" />
  </process>

  <!-- ═══ PROCESS SERVER ═══ -->
  <process id="Proc_Server" isExecutable="false">
    <laneSet id="LaneSet_Server">
      <lane id="Lane_S_RSA" name="RSA Key Exchange">
        <flowNodeRef>Start_S</flowNodeRef>
        <flowNodeRef>Task_S_SendPubKey</flowNodeRef>
        <flowNodeRef>Task_S_ReceiveKeyExchange</flowNodeRef>
        <flowNodeRef>Task_S_DecryptRSA</flowNodeRef>
      </lane>
      <lane id="Lane_S_Auth" name="Autentikasi (SHA-256 + Token)">
        <flowNodeRef>Task_S_ReceiveLoginReq</flowNodeRef>
        <flowNodeRef>Task_S_CheckDB</flowNodeRef>
        <flowNodeRef>GW_S_ValidCred</flowNodeRef>
        <flowNodeRef>Task_S_GenerateToken</flowNodeRef>
        <flowNodeRef>Task_S_SendLoginOK</flowNodeRef>
        <flowNodeRef>Task_S_SendLoginFail</flowNodeRef>
        <flowNodeRef>Task_S_LogSession</flowNodeRef>
        <flowNodeRef>Task_S_SendHistory</flowNodeRef>
        <flowNodeRef>Task_S_SendPending</flowNodeRef>
        <flowNodeRef>Task_S_SendNewToken</flowNodeRef>
      </lane>
      <lane id="Lane_S_Chat" name="Proses Pesan (Triple Cipher)">
        <flowNodeRef>Task_S_ReceiveChat</flowNodeRef>
        <flowNodeRef>Task_S_ValidateToken</flowNodeRef>
        <flowNodeRef>GW_S_TokenValid</flowNodeRef>
        <flowNodeRef>Task_S_DecryptSender</flowNodeRef>
        <flowNodeRef>Task_S_SaveDB</flowNodeRef>
        <flowNodeRef>GW_S_Online</flowNodeRef>
        <flowNodeRef>Task_S_ForwardMsg</flowNodeRef>
        <flowNodeRef>Task_S_MarkDelivered</flowNodeRef>
        <flowNodeRef>Task_S_Pending</flowNodeRef>
        <flowNodeRef>Task_S_SendError</flowNodeRef>
        <flowNodeRef>End_S</flowNodeRef>
        <flowNodeRef>End_S_Error</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="Start_S" name="Terima Koneksi&#10;TCP Client Baru" />
    <sequenceFlow id="SF_S1" sourceRef="Start_S" targetRef="Task_S_SendPubKey" />
    <task id="Task_S_SendPubKey" name="Kirim RSA Public Key&#10;(2048-bit, XML Base64)" />
    <sequenceFlow id="SF_S2" sourceRef="Task_S_SendPubKey" targetRef="Task_S_ReceiveKeyExchange" />
    <task id="Task_S_ReceiveKeyExchange" name="Terima KEY_EXCHANGE&#10;|encAesKey|encAesIV|" />
    <sequenceFlow id="SF_S3" sourceRef="Task_S_ReceiveKeyExchange" targetRef="Task_S_DecryptRSA" />
    <task id="Task_S_DecryptRSA" name="Dekripsi AES Key+IV&#10;pakai RSA Private Key&#10;→ AES Session Key" />
    <sequenceFlow id="SF_S4" sourceRef="Task_S_DecryptRSA" targetRef="Task_S_ReceiveLoginReq" />

    <task id="Task_S_ReceiveLoginReq" name="Terima LOGIN&#10;|username|sha256|" />
    <sequenceFlow id="SF_S5" sourceRef="Task_S_ReceiveLoginReq" targetRef="Task_S_CheckDB" />
    <task id="Task_S_CheckDB" name="SELECT FROM users&#10;WHERE username=?&#10;AND password_hash=?" />
    <sequenceFlow id="SF_S6" sourceRef="Task_S_CheckDB" targetRef="GW_S_ValidCred" />
    <exclusiveGateway id="GW_S_ValidCred" name="Valid?" />
    <sequenceFlow id="SF_S7a" name="Valid"       sourceRef="GW_S_ValidCred" targetRef="Task_S_GenerateToken" />
    <sequenceFlow id="SF_S7b" name="Tidak Valid"  sourceRef="GW_S_ValidCred" targetRef="Task_S_SendLoginFail" />
    <task id="Task_S_SendLoginFail" name="Kirim LOGIN_FAIL" />
    <sequenceFlow id="SF_S8" sourceRef="Task_S_SendLoginFail" targetRef="End_S_Error" />
    <task id="Task_S_GenerateToken" name="Generate Token&#10;GUID 32 char&#10;Expiry = +1 Jam" />
    <sequenceFlow id="SF_S9"  sourceRef="Task_S_GenerateToken" targetRef="Task_S_SendLoginOK" />
    <task id="Task_S_SendLoginOK" name="Kirim LOGIN_SUCCESS&#10;|role|token|expiry|" />
    <sequenceFlow id="SF_S10" sourceRef="Task_S_SendLoginOK" targetRef="Task_S_LogSession" />
    <task id="Task_S_LogSession" name="Simpan ke tabel sessions&#10;(Audit Trail, is_valid=1)" />
    <sequenceFlow id="SF_S11" sourceRef="Task_S_LogSession" targetRef="Task_S_SendHistory" />
    <task id="Task_S_SendHistory" name="Kirim HISTORY&#10;DbDecrypt → AesEncrypt&#10;→ Kirim ke Client" />
    <sequenceFlow id="SF_S12" sourceRef="Task_S_SendHistory" targetRef="Task_S_SendPending" />
    <task id="Task_S_SendPending" name="Kirim Pesan Pending&#10;(delivered=0)&#10;DbDecrypt → AesEncrypt" />
    <sequenceFlow id="SF_S13" sourceRef="Task_S_SendPending" targetRef="Task_S_ReceiveChat" />
    <task id="Task_S_SendNewToken" name="Generate Token Baru&#10;Kirim TOKEN_REFRESHED&#10;|newToken|expiry|" />
    <sequenceFlow id="SF_S_TR" sourceRef="Task_S_SendNewToken" targetRef="Task_S_ReceiveChat" />

    <task id="Task_S_ReceiveChat" name="Terima CHAT&#10;|from|to|cipher|token|" />
    <sequenceFlow id="SF_S14" sourceRef="Task_S_ReceiveChat" targetRef="Task_S_ValidateToken" />
    <task id="Task_S_ValidateToken" name="Validasi Token:&#10;cocok + belum expired?" />
    <sequenceFlow id="SF_S15" sourceRef="Task_S_ValidateToken" targetRef="GW_S_TokenValid" />
    <exclusiveGateway id="GW_S_TokenValid" name="Token&#10;Valid?" />
    <sequenceFlow id="SF_S16a" name="Valid"   sourceRef="GW_S_TokenValid" targetRef="Task_S_DecryptSender" />
    <sequenceFlow id="SF_S16b" name="Expired" sourceRef="GW_S_TokenValid" targetRef="Task_S_SendError" />
    <task id="Task_S_SendError" name="Kirim ERROR&#10;Session tidak valid&#10;Paksa Logout Client" />
    <sequenceFlow id="SF_S17" sourceRef="Task_S_SendError" targetRef="End_S_Error" />
    <task id="Task_S_DecryptSender" name="[Layer 1]&#10;AesDecrypt(cipher, aesKey_sender)&#10;→ Plaintext" />
    <sequenceFlow id="SF_S18" sourceRef="Task_S_DecryptSender" targetRef="Task_S_SaveDB" />
    <task id="Task_S_SaveDB" name="[Layer 2] message_encrypted = cipher&#10;[Layer 3] message_backup = DbEncrypt(plain)&#10;delivered = 0" />
    <sequenceFlow id="SF_S19" sourceRef="Task_S_SaveDB" targetRef="GW_S_Online" />
    <exclusiveGateway id="GW_S_Online" name="Recipient&#10;Online?" />
    <sequenceFlow id="SF_S20a" name="Online"  sourceRef="GW_S_Online" targetRef="Task_S_ForwardMsg" />
    <sequenceFlow id="SF_S20b" name="Offline" sourceRef="GW_S_Online" targetRef="Task_S_Pending" />
    <task id="Task_S_ForwardMsg" name="AesEncrypt(plain, aesKey_recipient)&#10;Kirim MSG ke Recipient&#10;Update delivered=1" />
    <sequenceFlow id="SF_S21" sourceRef="Task_S_ForwardMsg" targetRef="Task_S_MarkDelivered" />
    <task id="Task_S_MarkDelivered" name="SET delivered=1&#10;(Analogi: ✓✓ WhatsApp)" />
    <sequenceFlow id="SF_S22" sourceRef="Task_S_MarkDelivered" targetRef="End_S" />
    <task id="Task_S_Pending" name="Pesan Tetap di DB&#10;delivered=0&#10;Kirim saat Login" />
    <sequenceFlow id="SF_S23" sourceRef="Task_S_Pending" targetRef="End_S" />
    <endEvent id="End_S" name="Selesai" />
    <endEvent id="End_S_Error" name="Ditolak" />
  </process>

  <!-- ═══ DIAGRAM INTERCHANGE ═══ -->
  <bpmndi:BPMNDiagram id="Diagram_Security">
    <bpmndi:BPMNPlane id="Plane_Security" bpmnElement="Collab_Security">

      <!-- ═══ CLIENT POOL  x=60 y=40 w=2100 h=960 ═══ -->
      <bpmndi:BPMNShape id="Sh_Pool_Client" bpmnElement="Pool_Client" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="2100" height="960" />
      </bpmndi:BPMNShape>
      <!-- Lane 1: y=40..280 (h=240) -->
      <bpmndi:BPMNShape id="Sh_Lane_C1" bpmnElement="Lane_C_Password" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="2100" height="240" />
      </bpmndi:BPMNShape>
      <!-- Lane 2: y=280..520 (h=240) -->
      <bpmndi:BPMNShape id="Sh_Lane_C2" bpmnElement="Lane_C_KeyExchange" isHorizontal="true">
        <dc:Bounds x="60" y="280" width="2100" height="240" />
      </bpmndi:BPMNShape>
      <!-- Lane 3: y=520..760 (h=240) -->
      <bpmndi:BPMNShape id="Sh_Lane_C3" bpmnElement="Lane_C_Session" isHorizontal="true">
        <dc:Bounds x="60" y="520" width="2100" height="240" />
      </bpmndi:BPMNShape>
      <!-- Lane 4: y=760..1000 (h=240) -->
      <bpmndi:BPMNShape id="Sh_Lane_C4" bpmnElement="Lane_C_Chat" isHorizontal="true">
        <dc:Bounds x="60" y="760" width="2100" height="240" />
      </bpmndi:BPMNShape>

      <!-- ── Lane 1 Nodes (center y=160) ── -->
      <bpmndi:BPMNShape id="Sh_Start_C" bpmnElement="Start_C">
        <dc:Bounds x="272" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_InputCred" bpmnElement="Task_C_InputCredential">
        <dc:Bounds x="680" y="120" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_HashPw" bpmnElement="Task_C_HashPassword">
        <dc:Bounds x="880" y="120" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_GW_RegOrLogin" bpmnElement="GW_C_RegOrLogin" isMarkerVisible="true">
        <dc:Bounds x="1085" y="135" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendRegister" bpmnElement="Task_C_SendRegister">
        <dc:Bounds x="1185" y="90" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendLogin" bpmnElement="Task_C_SendLogin">
        <dc:Bounds x="1185" y="180" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Lane 2 Nodes (center y=400) ── -->
      <bpmndi:BPMNShape id="Sh_ReceivePubKey" bpmnElement="Task_C_ReceivePubKey">
        <dc:Bounds x="310" y="360" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_GenAES" bpmnElement="Task_C_GenerateAES">
        <dc:Bounds x="510" y="360" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_EncAES" bpmnElement="Task_C_EncryptAES">
        <dc:Bounds x="710" y="360" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendKX" bpmnElement="Task_C_SendKeyExchange">
        <dc:Bounds x="910" y="360" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Lane 3 Nodes (center y=620, lower row y=700) ── -->
      <bpmndi:BPMNShape id="Sh_RecvLoginOK" bpmnElement="Task_C_ReceiveLoginOK">
        <dc:Bounds x="310" y="580" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_RecvLoginFail" bpmnElement="Task_C_ReceiveLoginFail">
        <dc:Bounds x="310" y="680" width="150" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_End_LoginFail" bpmnElement="End_C_LoginFail">
        <dc:Bounds x="512" y="692" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_StoreToken" bpmnElement="Task_C_StoreToken">
        <dc:Bounds x="510" y="580" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_RecvHistory" bpmnElement="Task_C_ReceiveHistory">
        <dc:Bounds x="710" y="580" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_TokenCountdown" bpmnElement="Task_C_TokenCountdown">
        <dc:Bounds x="910" y="580" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_GW_TokenExp" bpmnElement="GW_C_TokenExpiring" isMarkerVisible="true">
        <dc:Bounds x="1115" y="595" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_ReqRefresh" bpmnElement="Task_C_RequestRefresh">
        <dc:Bounds x="1215" y="580" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_RecvNewToken" bpmnElement="Task_C_ReceiveNewToken">
        <dc:Bounds x="1415" y="580" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Lane 4 Nodes (center y=860) ── -->
      <bpmndi:BPMNShape id="Sh_EncMsg" bpmnElement="Task_C_EncryptMsg">
        <dc:Bounds x="310" y="820" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendChat" bpmnElement="Task_C_SendChat">
        <dc:Bounds x="510" y="820" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_RecvMsg" bpmnElement="Task_C_ReceiveMsg">
        <dc:Bounds x="710" y="820" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_DecMsg" bpmnElement="Task_C_DecryptMsg">
        <dc:Bounds x="910" y="820" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_DisplayMsg" bpmnElement="Task_C_DisplayMsg">
        <dc:Bounds x="1110" y="820" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_End_C" bpmnElement="End_C">
        <dc:Bounds x="1312" y="842" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ═══ SERVER POOL  x=60 y=1060 w=2100 h=860 ═══ -->
      <bpmndi:BPMNShape id="Sh_Pool_Server" bpmnElement="Pool_Server" isHorizontal="true">
        <dc:Bounds x="60" y="1060" width="2100" height="860" />
      </bpmndi:BPMNShape>
      <!-- Lane RSA: y=1060..1270 (h=210) -->
      <bpmndi:BPMNShape id="Sh_Lane_S_RSA" bpmnElement="Lane_S_RSA" isHorizontal="true">
        <dc:Bounds x="60" y="1060" width="2100" height="210" />
      </bpmndi:BPMNShape>
      <!-- Lane Auth: y=1270..1590 (h=320) -->
      <bpmndi:BPMNShape id="Sh_Lane_S_Auth" bpmnElement="Lane_S_Auth" isHorizontal="true">
        <dc:Bounds x="60" y="1270" width="2100" height="320" />
      </bpmndi:BPMNShape>
      <!-- Lane Chat: y=1590..1920 (h=330) -->
      <bpmndi:BPMNShape id="Sh_Lane_S_Chat" bpmnElement="Lane_S_Chat" isHorizontal="true">
        <dc:Bounds x="60" y="1590" width="2100" height="330" />
      </bpmndi:BPMNShape>

      <!-- ── Lane RSA Nodes (center y=1165) ── -->
      <bpmndi:BPMNShape id="Sh_Start_S" bpmnElement="Start_S">
        <dc:Bounds x="262" y="1147" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendPubKey" bpmnElement="Task_S_SendPubKey">
        <dc:Bounds x="340" y="1125" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_RecvKX" bpmnElement="Task_S_ReceiveKeyExchange">
        <dc:Bounds x="540" y="1125" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_DecRSA" bpmnElement="Task_S_DecryptRSA">
        <dc:Bounds x="740" y="1125" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Lane Auth Nodes (main row y=1330, fail row y=1460) ── -->
      <bpmndi:BPMNShape id="Sh_RecvLoginReq" bpmnElement="Task_S_ReceiveLoginReq">
        <dc:Bounds x="310" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_CheckDB" bpmnElement="Task_S_CheckDB">
        <dc:Bounds x="510" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_GW_ValidCred" bpmnElement="GW_S_ValidCred" isMarkerVisible="true">
        <dc:Bounds x="715" y="1345" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_GenToken" bpmnElement="Task_S_GenerateToken">
        <dc:Bounds x="815" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendLoginOK" bpmnElement="Task_S_SendLoginOK">
        <dc:Bounds x="1015" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_LogSession" bpmnElement="Task_S_LogSession">
        <dc:Bounds x="1215" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendHistory" bpmnElement="Task_S_SendHistory">
        <dc:Bounds x="1415" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendPending" bpmnElement="Task_S_SendPending">
        <dc:Bounds x="1615" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendNewToken" bpmnElement="Task_S_SendNewToken">
        <dc:Bounds x="1815" y="1330" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendLoginFail" bpmnElement="Task_S_SendLoginFail">
        <dc:Bounds x="715" y="1470" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Lane Chat Nodes (main row y=1640, error row y=1780) ── -->
      <bpmndi:BPMNShape id="Sh_RecvChat" bpmnElement="Task_S_ReceiveChat">
        <dc:Bounds x="310" y="1640" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_ValidateToken" bpmnElement="Task_S_ValidateToken">
        <dc:Bounds x="510" y="1640" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_GW_TokenValid" bpmnElement="GW_S_TokenValid" isMarkerVisible="true">
        <dc:Bounds x="715" y="1655" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_DecSender" bpmnElement="Task_S_DecryptSender">
        <dc:Bounds x="815" y="1640" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SaveDB" bpmnElement="Task_S_SaveDB">
        <dc:Bounds x="1015" y="1640" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_GW_Online" bpmnElement="GW_S_Online" isMarkerVisible="true">
        <dc:Bounds x="1220" y="1655" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_ForwardMsg" bpmnElement="Task_S_ForwardMsg">
        <dc:Bounds x="1320" y="1620" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_MarkDelivered" bpmnElement="Task_S_MarkDelivered">
        <dc:Bounds x="1520" y="1620" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_End_S" bpmnElement="End_S">
        <dc:Bounds x="1722" y="1642" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_Pending" bpmnElement="Task_S_Pending">
        <dc:Bounds x="1320" y="1780" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_SendError" bpmnElement="Task_S_SendError">
        <dc:Bounds x="815" y="1780" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_End_S_Error" bpmnElement="End_S_Error">
        <dc:Bounds x="1022" y="1802" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ═══ SEQUENCE FLOW EDGES — CLIENT ═══ -->
      <!-- Start → ReceivePubKey (L1→L2, down) -->
      <bpmndi:BPMNEdge id="Ed_C1" bpmnElement="SF_C1">
        <di:waypoint x="290" y="178" /><di:waypoint x="290" y="360" />
      </bpmndi:BPMNEdge>
      <!-- ReceivePubKey → GenerateAES -->
      <bpmndi:BPMNEdge id="Ed_C2" bpmnElement="SF_C2">
        <di:waypoint x="460" y="400" /><di:waypoint x="510" y="400" />
      </bpmndi:BPMNEdge>
      <!-- GenerateAES → EncryptAES -->
      <bpmndi:BPMNEdge id="Ed_C3" bpmnElement="SF_C3">
        <di:waypoint x="660" y="400" /><di:waypoint x="710" y="400" />
      </bpmndi:BPMNEdge>
      <!-- EncryptAES → SendKeyExchange -->
      <bpmndi:BPMNEdge id="Ed_C4" bpmnElement="SF_C4">
        <di:waypoint x="860" y="400" /><di:waypoint x="910" y="400" />
      </bpmndi:BPMNEdge>
      <!-- SendKeyExchange → InputCredential (L2→L1, up+left) -->
      <bpmndi:BPMNEdge id="Ed_C5" bpmnElement="SF_C5">
        <di:waypoint x="985" y="360" /><di:waypoint x="985" y="280" /><di:waypoint x="755" y="280" /><di:waypoint x="755" y="200" />
      </bpmndi:BPMNEdge>
      <!-- InputCredential → HashPassword -->
      <bpmndi:BPMNEdge id="Ed_C6" bpmnElement="SF_C6">
        <di:waypoint x="830" y="160" /><di:waypoint x="880" y="160" />
      </bpmndi:BPMNEdge>
      <!-- HashPassword → GW_RegOrLogin -->
      <bpmndi:BPMNEdge id="Ed_C7" bpmnElement="SF_C7">
        <di:waypoint x="1030" y="160" /><di:waypoint x="1085" y="160" />
      </bpmndi:BPMNEdge>
      <!-- GW → SendRegister (up) -->
      <bpmndi:BPMNEdge id="Ed_C8a" bpmnElement="SF_C8a">
        <di:waypoint x="1110" y="135" /><di:waypoint x="1110" y="115" /><di:waypoint x="1185" y="115" />
      </bpmndi:BPMNEdge>
      <!-- GW → SendLogin (down) -->
      <bpmndi:BPMNEdge id="Ed_C8b" bpmnElement="SF_C8b">
        <di:waypoint x="1110" y="185" /><di:waypoint x="1110" y="215" /><di:waypoint x="1185" y="215" />
      </bpmndi:BPMNEdge>
      <!-- SendRegister → ReceiveLoginOK (L1→L3, long down+left) -->
      <bpmndi:BPMNEdge id="Ed_C9" bpmnElement="SF_C9">
        <di:waypoint x="1335" y="130" /><di:waypoint x="1560" y="130" /><di:waypoint x="1560" y="620" /><di:waypoint x="460" y="620" />
      </bpmndi:BPMNEdge>
      <!-- SendLogin → ReceiveLoginOK -->
      <bpmndi:BPMNEdge id="Ed_C10" bpmnElement="SF_C10">
        <di:waypoint x="1335" y="220" /><di:waypoint x="1580" y="220" /><di:waypoint x="1580" y="635" /><di:waypoint x="460" y="635" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveLoginOK → StoreToken -->
      <bpmndi:BPMNEdge id="Ed_C11a" bpmnElement="SF_C11a">
        <di:waypoint x="460" y="620" /><di:waypoint x="510" y="620" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveLoginFail → End_LoginFail -->
      <bpmndi:BPMNEdge id="Ed_C11b" bpmnElement="SF_C11b">
        <di:waypoint x="460" y="710" /><di:waypoint x="512" y="710" />
      </bpmndi:BPMNEdge>
      <!-- StoreToken → ReceiveHistory -->
      <bpmndi:BPMNEdge id="Ed_C12" bpmnElement="SF_C12">
        <di:waypoint x="660" y="620" /><di:waypoint x="710" y="620" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveHistory → TokenCountdown -->
      <bpmndi:BPMNEdge id="Ed_C13" bpmnElement="SF_C13">
        <di:waypoint x="860" y="620" /><di:waypoint x="910" y="620" />
      </bpmndi:BPMNEdge>
      <!-- TokenCountdown → GW -->
      <bpmndi:BPMNEdge id="Ed_C14" bpmnElement="SF_C14">
        <di:waypoint x="1060" y="620" /><di:waypoint x="1115" y="620" />
      </bpmndi:BPMNEdge>
      <!-- GW → RequestRefresh (Ya) -->
      <bpmndi:BPMNEdge id="Ed_C15a" bpmnElement="SF_C15a">
        <di:waypoint x="1165" y="620" /><di:waypoint x="1215" y="620" />
      </bpmndi:BPMNEdge>
      <!-- GW → EncryptMsg (Tidak, L3→L4, down) -->
      <bpmndi:BPMNEdge id="Ed_C15b" bpmnElement="SF_C15b">
        <di:waypoint x="1140" y="645" /><di:waypoint x="1140" y="760" /><di:waypoint x="385" y="760" /><di:waypoint x="385" y="820" />
      </bpmndi:BPMNEdge>
      <!-- RequestRefresh → ReceiveNewToken -->
      <bpmndi:BPMNEdge id="Ed_C16" bpmnElement="SF_C16">
        <di:waypoint x="1365" y="620" /><di:waypoint x="1415" y="620" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveNewToken → EncryptMsg (L3→L4, down+left) -->
      <bpmndi:BPMNEdge id="Ed_C17" bpmnElement="SF_C17">
        <di:waypoint x="1490" y="660" /><di:waypoint x="1490" y="775" /><di:waypoint x="385" y="775" /><di:waypoint x="385" y="820" />
      </bpmndi:BPMNEdge>
      <!-- EncryptMsg → SendChat -->
      <bpmndi:BPMNEdge id="Ed_C18" bpmnElement="SF_C18">
        <di:waypoint x="460" y="860" /><di:waypoint x="510" y="860" />
      </bpmndi:BPMNEdge>
      <!-- SendChat → ReceiveMsg -->
      <bpmndi:BPMNEdge id="Ed_C19" bpmnElement="SF_C19">
        <di:waypoint x="660" y="860" /><di:waypoint x="710" y="860" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveMsg → DecryptMsg -->
      <bpmndi:BPMNEdge id="Ed_C20" bpmnElement="SF_C20">
        <di:waypoint x="860" y="860" /><di:waypoint x="910" y="860" />
      </bpmndi:BPMNEdge>
      <!-- DecryptMsg → DisplayMsg -->
      <bpmndi:BPMNEdge id="Ed_C21" bpmnElement="SF_C21">
        <di:waypoint x="1060" y="860" /><di:waypoint x="1110" y="860" />
      </bpmndi:BPMNEdge>
      <!-- DisplayMsg → End_C -->
      <bpmndi:BPMNEdge id="Ed_C22" bpmnElement="SF_C22">
        <di:waypoint x="1260" y="860" /><di:waypoint x="1312" y="860" />
      </bpmndi:BPMNEdge>

      <!-- ═══ SEQUENCE FLOW EDGES — SERVER ═══ -->
      <!-- Start → SendPubKey -->
      <bpmndi:BPMNEdge id="Ed_S1" bpmnElement="SF_S1">
        <di:waypoint x="298" y="1165" /><di:waypoint x="340" y="1165" />
      </bpmndi:BPMNEdge>
      <!-- SendPubKey → ReceiveKeyExchange -->
      <bpmndi:BPMNEdge id="Ed_S2" bpmnElement="SF_S2">
        <di:waypoint x="490" y="1165" /><di:waypoint x="540" y="1165" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveKX → DecryptRSA -->
      <bpmndi:BPMNEdge id="Ed_S3" bpmnElement="SF_S3">
        <di:waypoint x="690" y="1165" /><di:waypoint x="740" y="1165" />
      </bpmndi:BPMNEdge>
      <!-- DecryptRSA → ReceiveLoginReq (L_RSA→L_Auth, down+left) -->
      <bpmndi:BPMNEdge id="Ed_S4" bpmnElement="SF_S4">
        <di:waypoint x="815" y="1205" /><di:waypoint x="815" y="1270" /><di:waypoint x="385" y="1270" /><di:waypoint x="385" y="1330" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveLoginReq → CheckDB -->
      <bpmndi:BPMNEdge id="Ed_S5" bpmnElement="SF_S5">
        <di:waypoint x="460" y="1370" /><di:waypoint x="510" y="1370" />
      </bpmndi:BPMNEdge>
      <!-- CheckDB → GW_ValidCred -->
      <bpmndi:BPMNEdge id="Ed_S6" bpmnElement="SF_S6">
        <di:waypoint x="660" y="1370" /><di:waypoint x="715" y="1370" />
      </bpmndi:BPMNEdge>
      <!-- GW → GenerateToken (Valid) -->
      <bpmndi:BPMNEdge id="Ed_S7a" bpmnElement="SF_S7a">
        <di:waypoint x="765" y="1370" /><di:waypoint x="815" y="1370" />
      </bpmndi:BPMNEdge>
      <!-- GW → SendLoginFail (Tidak Valid) -->
      <bpmndi:BPMNEdge id="Ed_S7b" bpmnElement="SF_S7b">
        <di:waypoint x="740" y="1395" /><di:waypoint x="740" y="1470" />
      </bpmndi:BPMNEdge>
      <!-- SendLoginFail → End_S_Error (L_Auth→L_Chat, down) -->
      <bpmndi:BPMNEdge id="Ed_S8" bpmnElement="SF_S8">
        <di:waypoint x="790" y="1550" /><di:waypoint x="790" y="1820" /><di:waypoint x="1022" y="1820" />
      </bpmndi:BPMNEdge>
      <!-- GenerateToken → SendLoginOK -->
      <bpmndi:BPMNEdge id="Ed_S9" bpmnElement="SF_S9">
        <di:waypoint x="965" y="1370" /><di:waypoint x="1015" y="1370" />
      </bpmndi:BPMNEdge>
      <!-- SendLoginOK → LogSession -->
      <bpmndi:BPMNEdge id="Ed_S10" bpmnElement="SF_S10">
        <di:waypoint x="1165" y="1370" /><di:waypoint x="1215" y="1370" />
      </bpmndi:BPMNEdge>
      <!-- LogSession → SendHistory -->
      <bpmndi:BPMNEdge id="Ed_S11" bpmnElement="SF_S11">
        <di:waypoint x="1365" y="1370" /><di:waypoint x="1415" y="1370" />
      </bpmndi:BPMNEdge>
      <!-- SendHistory → SendPending -->
      <bpmndi:BPMNEdge id="Ed_S12" bpmnElement="SF_S12">
        <di:waypoint x="1565" y="1370" /><di:waypoint x="1615" y="1370" />
      </bpmndi:BPMNEdge>
      <!-- SendPending → ReceiveChat (L_Auth→L_Chat, down+left) -->
      <bpmndi:BPMNEdge id="Ed_S13" bpmnElement="SF_S13">
        <di:waypoint x="1690" y="1410" /><di:waypoint x="1690" y="1600" /><di:waypoint x="385" y="1600" /><di:waypoint x="385" y="1640" />
      </bpmndi:BPMNEdge>
      <!-- SendPending → SendNewToken -->
      <bpmndi:BPMNEdge id="Ed_S12b" bpmnElement="SF_S_TR">
        <di:waypoint x="1890" y="1410" /><di:waypoint x="1890" y="1615" /><di:waypoint x="375" y="1615" /><di:waypoint x="375" y="1640" />
      </bpmndi:BPMNEdge>
      <!-- ReceiveChat → ValidateToken -->
      <bpmndi:BPMNEdge id="Ed_S14" bpmnElement="SF_S14">
        <di:waypoint x="460" y="1680" /><di:waypoint x="510" y="1680" />
      </bpmndi:BPMNEdge>
      <!-- ValidateToken → GW_TokenValid -->
      <bpmndi:BPMNEdge id="Ed_S15" bpmnElement="SF_S15">
        <di:waypoint x="660" y="1680" /><di:waypoint x="715" y="1680" />
      </bpmndi:BPMNEdge>
      <!-- GW → DecryptSender (Valid) -->
      <bpmndi:BPMNEdge id="Ed_S16a" bpmnElement="SF_S16a">
        <di:waypoint x="765" y="1680" /><di:waypoint x="815" y="1680" />
      </bpmndi:BPMNEdge>
      <!-- GW → SendError (Expired) -->
      <bpmndi:BPMNEdge id="Ed_S16b" bpmnElement="SF_S16b">
        <di:waypoint x="740" y="1705" /><di:waypoint x="740" y="1820" /><di:waypoint x="815" y="1820" />
      </bpmndi:BPMNEdge>
      <!-- SendError → End_S_Error -->
      <bpmndi:BPMNEdge id="Ed_S17" bpmnElement="SF_S17">
        <di:waypoint x="965" y="1820" /><di:waypoint x="1022" y="1820" />
      </bpmndi:BPMNEdge>
      <!-- DecryptSender → SaveDB -->
      <bpmndi:BPMNEdge id="Ed_S18" bpmnElement="SF_S18">
        <di:waypoint x="965" y="1680" /><di:waypoint x="1015" y="1680" />
      </bpmndi:BPMNEdge>
      <!-- SaveDB → GW_Online -->
      <bpmndi:BPMNEdge id="Ed_S19" bpmnElement="SF_S19">
        <di:waypoint x="1165" y="1680" /><di:waypoint x="1220" y="1680" />
      </bpmndi:BPMNEdge>
      <!-- GW → ForwardMsg (Online) -->
      <bpmndi:BPMNEdge id="Ed_S20a" bpmnElement="SF_S20a">
        <di:waypoint x="1270" y="1680" /><di:waypoint x="1320" y="1660" />
      </bpmndi:BPMNEdge>
      <!-- GW → Pending (Offline) -->
      <bpmndi:BPMNEdge id="Ed_S20b" bpmnElement="SF_S20b">
        <di:waypoint x="1245" y="1705" /><di:waypoint x="1245" y="1820" /><di:waypoint x="1320" y="1820" />
      </bpmndi:BPMNEdge>
      <!-- ForwardMsg → MarkDelivered -->
      <bpmndi:BPMNEdge id="Ed_S21" bpmnElement="SF_S21">
        <di:waypoint x="1470" y="1660" /><di:waypoint x="1520" y="1660" />
      </bpmndi:BPMNEdge>
      <!-- MarkDelivered → End_S -->
      <bpmndi:BPMNEdge id="Ed_S22" bpmnElement="SF_S22">
        <di:waypoint x="1670" y="1660" /><di:waypoint x="1722" y="1660" />
      </bpmndi:BPMNEdge>
      <!-- Pending → End_S -->
      <bpmndi:BPMNEdge id="Ed_S23" bpmnElement="SF_S23">
        <di:waypoint x="1470" y="1820" /><di:waypoint x="1740" y="1820" /><di:waypoint x="1740" y="1678" />
      </bpmndi:BPMNEdge>

      <!-- ═══ MESSAGE FLOWS (gap area y=1020..1060) ═══ -->
      <!-- PUBKEY: SendPubKey → ReceivePubKey -->
      <bpmndi:BPMNEdge id="Ed_MF_PubKey" bpmnElement="MF_PubKey">
        <di:waypoint x="415" y="1125" /><di:waypoint x="415" y="1042" /><di:waypoint x="385" y="1042" /><di:waypoint x="385" y="440" />
      </bpmndi:BPMNEdge>
      <!-- KEY_EXCHANGE: SendKeyExchange → ReceiveKeyExchange -->
      <bpmndi:BPMNEdge id="Ed_MF_KX" bpmnElement="MF_KeyExchange">
        <di:waypoint x="985" y="440" /><di:waypoint x="985" y="1050" /><di:waypoint x="615" y="1050" /><di:waypoint x="615" y="1125" />
      </bpmndi:BPMNEdge>
      <!-- LOGIN_SUCCESS: SendLoginOK → ReceiveLoginOK -->
      <bpmndi:BPMNEdge id="Ed_MF_LoginOK" bpmnElement="MF_LoginSuccess">
        <di:waypoint x="1090" y="1330" /><di:waypoint x="1090" y="1032" /><di:waypoint x="385" y="1032" /><di:waypoint x="385" y="660" />
      </bpmndi:BPMNEdge>
      <!-- LOGIN_FAIL: SendLoginFail → ReceiveLoginFail -->
      <bpmndi:BPMNEdge id="Ed_MF_LoginFail" bpmnElement="MF_LoginFail">
        <di:waypoint x="790" y="1470" /><di:waypoint x="790" y="1022" /><di:waypoint x="385" y="1022" /><di:waypoint x="385" y="740" />
      </bpmndi:BPMNEdge>
      <!-- CHAT: SendChat → ReceiveChat -->
      <bpmndi:BPMNEdge id="Ed_MF_Chat" bpmnElement="MF_ChatMsg">
        <di:waypoint x="585" y="900" /><di:waypoint x="585" y="1058" /><di:waypoint x="385" y="1058" /><di:waypoint x="385" y="1640" />
      </bpmndi:BPMNEdge>
      <!-- MSG: ForwardMsg → ReceiveMsg -->
      <bpmndi:BPMNEdge id="Ed_MF_Msg" bpmnElement="MF_MsgDelivery">
        <di:waypoint x="1395" y="1620" /><di:waypoint x="1395" y="1038" /><di:waypoint x="785" y="1038" /><di:waypoint x="785" y="900" />
      </bpmndi:BPMNEdge>
      <!-- HISTORY: SendHistory → ReceiveHistory -->
      <bpmndi:BPMNEdge id="Ed_MF_History" bpmnElement="MF_History">
        <di:waypoint x="1490" y="1330" /><di:waypoint x="1490" y="1028" /><di:waypoint x="785" y="1028" /><di:waypoint x="785" y="660" />
      </bpmndi:BPMNEdge>
      <!-- TOKEN_REFRESHED: SendNewToken → ReceiveNewToken -->
      <bpmndi:BPMNEdge id="Ed_MF_Token" bpmnElement="MF_TokenRefresh">
        <di:waypoint x="1890" y="1330" /><di:waypoint x="1890" y="1018" /><di:waypoint x="1490" y="1018" /><di:waypoint x="1490" y="660" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
